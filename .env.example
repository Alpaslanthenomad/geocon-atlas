# GEOCON Atlas — environment variable template.
# Copy to .env.local for local dev (already gitignored), or set the
# same keys in Vercel project settings → Environment Variables for
# production.
#
# Categories (header comments below):
#   1. Supabase      — REQUIRED, the app won't start without these
#   2. ORCID OAuth   — optional, K9 OAuth verification
#   3. AI            — optional, K10 welcome suggestions + harvest enrichment
#   4. External APIs — optional, each harvester gracefully falls back
#   5. Cron / admin  — protects scheduled harvest endpoints
#   6. Observability — optional, Sentry + PostHog
#
# See docs/DEPLOY.md for setup walkthroughs.

# ─── 1. Supabase (REQUIRED) ──────────────────────────────────
# From Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ…
SUPABASE_SERVICE_ROLE_KEY=eyJ…             # SERVER-ONLY, never expose to client

# ─── 2. ORCID OAuth (K9 verification) ────────────────────────
# Register an app at https://orcid.org/developer-tools — see
# docs/setup/orcid-oauth.md for the full walkthrough.
# When unset, the manual ORCID flow still works; the "ORCID ile
# doğrula" button returns 503.
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=                       # uzun random string; bir daha gösterilmez
ORCID_REDIRECT_URI=https://geocon.bio/api/auth/orcid/callback
ORCID_ENV=production                       # or "sandbox" for sandbox.orcid.org

# ─── 3. AI (Anthropic — Claude Haiku 4.5 by default) ─────────
# Used by:
#   - /api/welcome/suggestions       (K10 personalized welcome)
#   - /api/harvest/enrichment        (researcher expertise tagging)
#   - /api/harvest/score-researchers (priority scoring)
#   - several other harvest scripts
# When unset, all AI-dependent endpoints fall back to defaults.
ANTHROPIC_API_KEY=sk-ant-…

# ─── 4. External APIs (harvesters) ───────────────────────────
# All optional — each harvester logs a warning and skips if missing.
IUCN_API_TOKEN=                            # see docs/iucn-api-reapplication.md
NCBI_API_KEY=                              # PubMed (raises rate limit 3 → 10 rps)
SEMANTIC_SCHOLAR_API_KEY=                  # Optional; default IP-based quota

# ─── 5. Cron / admin protection ──────────────────────────────
# Sent as ?secret=… or Authorization: Bearer … to harvest endpoints.
# Vercel Cron sets this automatically when you configure scheduled
# functions; set the same value here and on cron jobs.
CRON_SECRET=

# ─── 6. Observability (Sentry + PostHog) ─────────────────────
# Sentry: register at sentry.io, create a Next.js project, paste the
# DSN. The build-time SENTRY_AUTH_TOKEN is only needed if you want
# source maps uploaded.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog (product analytics, optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
